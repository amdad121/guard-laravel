includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:
    level: 4
    paths:
        - src
    tmpDir: build/phpstan
    checkOctaneCompatibility: true
    checkModelProperties: false
    ignoreErrors:
        -
            message: '#Trait AmdadulHaq\\Guard\\Concerns\\Roleable is used zero times and is not analysed\.#'
            path: src/Concerns/Roleable.php
